# Embedded Observability Platform — Relay / Backend Environment
# ---------------------------------------------------------------
# Copy this file to `.env` in the same folder and fill in real values:
#     cp .env.example .env
#
# The real `.env` is git-ignored; never commit credentials.

# MongoDB connection string.
#  - Local dev:   mongodb://localhost:27017/embedded_obs
#  - Atlas free:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/embedded_obs
MONGO_URI=mongodb://localhost:27017/embedded_obs
